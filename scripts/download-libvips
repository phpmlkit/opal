#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
LIB_DIR="${PROJECT_ROOT}/lib"
VERSION_FILE="${PROJECT_ROOT}/libvips-version"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

print_heading() {
    echo -e "${GREEN}$1${NC}"
}

print_item() {
    local label="$1"
    local value="$2"
    echo -e "  - ${label}: ${YELLOW}${value}${NC}"
}

print_detail() {
    echo -e "  - $1"
}

print_warning() {
    echo -e "  - ${YELLOW}Warning${NC}: $1"
}

log_error() {
    echo -e "${RED}Error${NC}: $1" >&2
}

detect_platform() {
  local os arch
  case "$(uname -s)" in
    Linux)  os="linux" ;;
    Darwin) os="darwin" ;;
    MINGW*|MSYS*|CYGWIN*) os="windows" ;;
    *) log_error "Unsupported OS: $(uname -s)"; exit 1 ;;
  esac

  arch=$(uname -m)
  case "$arch" in
    x86_64|amd64) arch="x86_64" ;;
    arm64|aarch64) arch="arm64" ;;
    *) log_error "Unsupported arch: $arch"; exit 1 ;;
  esac

  if [ "$os" = "windows" ]; then
    echo "windows-64"
  else
    echo "${os}-${arch}"
  fi
}

main() {
  local platform="${1:-$(detect_platform)}"
  local version="${2:-$(cat "$VERSION_FILE" 2>/dev/null || echo "8.18.2")}"

  local binaries_platform
  case "$platform" in
    darwin-arm64)   binaries_platform="darwin-arm64" ;;
    darwin-x86_64)  binaries_platform="darwin-x64" ;;
    linux-x86_64)   binaries_platform="linux-x64" ;;
    linux-arm64)    binaries_platform="linux-arm64" ;;
    windows-64)     binaries_platform="win-x64" ;;
    *)              binaries_platform="$platform" ;;
  esac

  local ext
  case "$platform" in
    windows-*) ext="zip" ;;
    *) ext="tar.gz" ;;
  esac

  local filename="libvips-${binaries_platform}.${ext}"
  local url="https://github.com/phpmlkit/libvips-binaries/releases/download/${version}/${filename}"
  local target_dir="${LIB_DIR}/${platform}"

  local lib_name=""
  case "$platform" in
    darwin-*) lib_name="libvips.*.dylib" ;;
    linux-*)  lib_name="libvips.so.*" ;;
    windows-*) lib_name="*.dll" ;;
  esac

  print_heading "Setting up libvips binaries"

  if [ -d "$target_dir" ] && ls "$target_dir"/$lib_name 2>/dev/null >/dev/null; then
    echo -e "${GREEN}Libvips already installed for ${YELLOW}${platform}${NC}"

    # DEBUG: show installed files (remove once Windows CI is confirmed working)
    print_detail "Contents of ${target_dir}:"
    find "${target_dir}" -type f | sed 's/^/    /' || true

    return 0
  fi

  print_detail "Downloading ${GREEN}libvips${NC} (${YELLOW}${version}, ${platform}${NC})"

  mkdir -p "$target_dir"
  local tmpdir
  tmpdir=$(mktemp -d)
  trap "rm -rf \"$tmpdir\"" EXIT

  if command -v curl >/dev/null; then
    curl -sL --retry 3 --retry-max-time 30 -o "${tmpdir}/archive.${ext}" "$url"
  elif command -v wget >/dev/null; then
    wget -q --tries=3 --timeout=30 -O "${tmpdir}/archive.${ext}" "$url"
  else
    log_error "curl or wget required"
    exit 1
  fi

  print_detail "Installing ${GREEN}libvips${NC} (${YELLOW}${version}, ${platform}${NC}): Extracting archive"

  case "$ext" in
    tar.gz) tar xzf "${tmpdir}/archive.${ext}" -C "$tmpdir" ;;
    zip)    unzip -q "${tmpdir}/archive.${ext}" -d "$tmpdir" ;;
  esac

  if [ -d "$tmpdir/lib" ]; then
    cp -R "$tmpdir/lib/"* "$target_dir/"
  else
    find "$tmpdir" -type f \( -name "*.dylib" -o -name "*.so*" -o -name "*.dll" \) -exec cp {} "$target_dir/" \;
  fi

  for f in versions.json THIRD-PARTY-NOTICES.md; do
    local found
    found=$(find "$tmpdir" -name "$f" -type f 2>/dev/null | head -1)
    if [ -n "$found" ]; then
      cp "$found" "$target_dir/"
    fi
  done

  print_heading "Installed libvips to lib/${platform}"

  # DEBUG: show what was installed (remove once Windows CI is confirmed working)
  print_detail "Contents of lib/:"
  find "${LIB_DIR}" -type f | sed 's/^/    /' || true
  print_detail "Contents of ${target_dir}:"
  find "${target_dir}" -type f | sed 's/^/    /' || true
}

main "$@"
