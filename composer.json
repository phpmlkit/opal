{
    "name": "phpmlkit/opal",
    "description": "High-performance image processing for PHP, backed by libvips via FFI.",
    "type": "platform-package",
    "license": "MIT",
    "authors": [
        {
            "name": "Kyrian Obikwelu",
            "email": "koshnawaza@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-ffi": "*",
        "codewithkyrian/platform-package-installer": "^2.0",
        "jcupitt/vips": "^2.0",
        "phpmlkit/ndarray": "^2.0"
    },
    "keywords": [
        "image",
        "image processing",
        "libvips",
        "vips",
        "ffi",
        "ml",
        "machine learning",
        "ndarray",
        "gd",
        "imagick"
    ],
    "support": {
        "issues": "https://github.com/phpmlkit/opal/issues",
        "source": "https://github.com/phpmlkit/opal"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0",
        "symfony/var-dumper": "^6.4.11|^7.1.5|^8.0"
    },
    "autoload": {
        "psr-4": {
            "PhpMlKit\\Opal\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "PhpMlKit\\Opal\\Tests\\": "tests/"
        }
    },
    "extra": {
        "artifacts": {
            "darwin-arm64": "https://github.com/phpmlkit/opal/releases/download/{version}/dist-darwin-arm64.tar.gz",
            "darwin-x86_64": "https://github.com/phpmlkit/opal/releases/download/{version}/dist-darwin-x86_64.tar.gz",
            "linux-x86_64": "https://github.com/phpmlkit/opal/releases/download/{version}/dist-linux-x86_64.tar.gz",
            "linux-arm64": "https://github.com/phpmlkit/opal/releases/download/{version}/dist-linux-arm64.tar.gz",
            "windows-64": "https://github.com/phpmlkit/opal/releases/download/{version}/dist-windows-64.zip"
        }
    },
    "scripts": {
        "post-install-cmd": "bash scripts/download-libvips",
        "post-update-cmd": "bash scripts/download-libvips",
        "test": "./vendor/bin/phpunit",
        "test:pretty": "./vendor/bin/phpunit --testdox",
        "test:coverage": "./vendor/bin/phpunit --coverage-text",
        "cs:fix": "./vendor/bin/php-cs-fixer fix",
        "cs:check": "./vendor/bin/php-cs-fixer fix --dry-run --diff",
        "lint": "./vendor/bin/phpstan analyse"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "codewithkyrian/platform-package-installer": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
